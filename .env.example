# ============================================================
# F5 XC Dashboard - Environment Configuration
# Copy to .env and fill in values. Do NOT commit .env.
# ============================================================

# --- Postgres ---
POSTGRES_USER=f5xc
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=f5xc_dashboard

# --- App secrets ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60

# --- Auth provider ---
# local | oidc  (oidc not implemented yet, stub only)
AUTH_PROVIDER=local

# --- OIDC (stub, not used until AUTH_PROVIDER=oidc) ---
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# --- F5 XC ---
# Set F5XC_MOCK=true to use fixture data instead of hitting the live API.
# Flip to false once you've validated the stack against <your-tenant>.
F5XC_MOCK=true
F5XC_TENANT=<your-tenant>
F5XC_API_TOKEN=
F5XC_NAMESPACE=<your-namespace>
F5XC_REQUEST_TIMEOUT_SECONDS=30
F5XC_MAX_RETRIES=5
# Tenant URL template. F5 XC tenants exist on either of two URL conventions
# depending on provisioning era. The {tenant} placeholder gets f5xc_tenant
# substituted in. Pick whichever resolves for your tenant:
#   https://{tenant}.console.ves.io        (modern, default)
#   https://{tenant}.ves.volterra.io       (legacy / many enterprise tenants)
# To confirm which one applies, run from inside the backend container:
#   curl -sI -H "Authorization: APIToken $F5XC_API_TOKEN" \
#     "https://$F5XC_TENANT.console.ves.io/api/web/namespaces" | head -1
# A 200/401/403 confirms the URL works; a DNS failure or 404 means try the other.
F5XC_API_URL_TEMPLATE=https://{tenant}.console.ves.io

# --- Polling cadence (seconds) ---
POLL_CONFIG_INTERVAL=600         # 10 min: LBs, pools, policies, certs
POLL_HEALTHCHECK_INTERVAL=120    # 2 min:  healthcheck status
POLL_ANALYTICS_INTERVAL=300      # 5 min:  WAF, Bot, API, Security events

# --- Cert expiry thresholds (days) ---
CERT_WARN_DAYS=30
CERT_CRITICAL_DAYS=7

# --- Frontend ---
# API_BASE_URL is the URL the Next.js server uses to proxy /api/* requests
# to the FastAPI backend. Inside Docker Compose the default "http://backend:8000"
# (set directly in docker-compose.yml) resolves to the backend service.
# Do NOT set NEXT_PUBLIC_API_BASE_URL — that would bake into the built image.

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
